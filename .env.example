# Runtime
# Prefer PYTHON_EXE for a fixed interpreter, or CONDA_ROOT + CONDA_ENV_NAME for Conda.
PYTHON_EXE=
CONDA_ENV_PYTHON=
CONDA_ROOT=
CONDA_ENV_NAME=

# Service addresses
APP_SCHEME=http
APP_HOST=127.0.0.1
APP_BIND_HOST=0.0.0.0
APP_LOOPBACK_HOST=127.0.0.1
FRONTEND_PORT=3000
EDUCATION_API_PORT=8001
MAINTENANCE_API_PORT=8002
BACKEND_ADMIN_PORT=8080

# Optional per-service bind hosts
FRONTEND_BIND_HOST=
EDUCATION_API_BIND_HOST=
MAINTENANCE_API_BIND_HOST=
BACKEND_ADMIN_BIND_HOST=

# Optional deployment/runtime storage overrides.
# On Render, keep these on the service filesystem for temporary data, or point
# them to a Persistent Disk mount such as /var/data for durable data.
APP_RUNTIME_DIR=
APP_DATA_DIR=
GRAPH_DB_PATH=
KNOWLEDGE_GRAPH_DB_PATH=

# Single FastAPI / Render graph bootstrap.
RENDER_AUTO_SYNC_STRUCTURED=1
RENDER_AUTO_SYNC_MIN_NODES=20

# Local demo login. Change these in .env for your environment.
APP_STUDENT_USERNAME=student
APP_STUDENT_PASSWORD=change-me
APP_STUDENT_ID=student_001
APP_TEACHER_USERNAME=teacher
APP_TEACHER_PASSWORD=change-me
APP_TEACHER_ID=teacher_001

# AI providers
DEEPSEEK_API_KEY=
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
# 0/empty means deep generation tasks (lecture/exercise bank) are not stopped mid-response.
DEEPSEEK_GENERATION_READ_TIMEOUT_SECONDS=0
OPENAI_API_KEY=
GEMINI_API_KEY=
